---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import CVSection from '../../components/CVSection.astro';
import SkillRating from '../../components/SkillRating.astro';
import { cvTranslations, cvLabels } from '../../i18n/cvData';
import { getLangFromUrl } from '../../i18n/utils';

export async function getStaticPaths() {
  return [{ params: { lang: 'hu' } }, { params: { lang: 'en' } }];
}

const lang = getLangFromUrl(Astro.url);
const cv = cvTranslations[lang];
const labels = cvLabels[lang];
---

<BaseLayout title={`${cv.personal.title}`}>
  <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row gap-16">
    <div class="md:w-64 flex-shrink-0">
      <div class="md:sticky md:top-24">
        <Sidebar />
      </div>
    </div>

    <main class="flex-1 max-w-3xl">
      <div class="mb-10">
        <h2 class="text-4xl font-extrabold text-slate-900">
          {cv.personal.title}
        </h2>
      </div>

      <CVSection title={labels.education}>
        {
          cv.education.map((item) => (
            <div class="grid grid-cols-1 sm:grid-cols-4 gap-2 sm:gap-6">
              <div class="text-sm font-semibold text-slate-500 tabular-nums">
                {item.period}
              </div>
              <div class="sm:col-span-3">
                <h4 class="font-bold text-slate-900 text-lg leading-snug">
                  {item.title}
                </h4>
                <p class="text-md text-slate-700 italic">{item.institution}</p>
                {item.bullets && (
                  <ul class="list-disc list-inside text-sm text-slate-600 mt-2 space-y-1">
                    {item.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
          ))
        }
      </CVSection>

      <CVSection title={labels.research}>
        <div class="space-y-8">
          <p class="text-slate-700 leading-relaxed italic">
            {cv.research.summary}
          </p>

          {/* Publikációk navigációs link */}
          <div class="py-2">
            <h4 class="text-lg font-bold text-slate-900 tracking-tight mb-2">
              {labels.publications}
            </h4>
            <a
              href={`/${lang}/publications`}
              class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 hover:underline transition-colors"
            >
              {labels.view_publications}
              <span class="ml-1">→</span>
            </a>
          </div>

          {/* Ösztöndíjak szekció */}
          <div class="space-y-4">
            <h4 class="text-lg font-bold text-slate-900 tracking-tight">
              {labels.grants}
            </h4>
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-100 text-sm">
                <thead>
                  <tr
                    class="text-left text-xs font-semibold uppercase tracking-wider text-slate-400"
                  >
                    <th scope="col" class="py-3 pr-4 w-32"
                      >{lang === 'hu' ? 'Időszak' : 'Period'}</th
                    >
                    <th scope="col" class="py-3 pl-4"
                      >{lang === 'hu' ? 'Megnevezés' : 'Description'}</th
                    >
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {
                    cv.research.grants.map((grant) => (
                      <tr>
                        <td class="py-3 pr-4 font-medium text-slate-400 tabular-nums whitespace-nowrap align-top">
                          {grant.period}
                        </td>
                        <td class="py-3 pl-4 font-bold text-slate-900 align-top leading-snug">
                          {grant.title}
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </CVSection>

      <CVSection title={labels.teaching}>
        <div class="grid grid-cols-2 gap-4 mb-6">
          {
            cv.teaching.stats.map((stat) => (
              <div class="bg-slate-50 p-4 border rounded text-center">
                <div class="text-2xl font-bold text-slate-900 tabular-nums">
                  {stat.count}
                </div>
                <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">
                  {stat.label}
                </div>
              </div>
            ))
          }
        </div>
        <ul class="list-disc list-inside text-sm text-slate-700 space-y-1">
          {cv.teaching.courses.map((course) => <li>{course}</li>)}
        </ul>
      </CVSection>

      <CVSection title={labels.activities}>
        <div class="space-y-10">
          {
            cv.activities.map((block) => (
              <div class="space-y-4">
                {/* Szervezet neve kiemelve */}
                <h4 class="text-xl font-bold text-slate-900 tracking-tight border-slate-900 pl-3">
                  {block.organization}
                </h4>

                {/* Pozíciók listázása a szervezeten binnen */}
                {block.roles.length > 0 ? (
                  <div class="space-y-6 mt-4 pl-4">
                    {block.roles.map((role) => (
                      <div class="grid grid-cols-1 sm:grid-cols-4 gap-2 sm:gap-6">
                        <div class="text-sm font-semibold text-slate-500 tabular-nums">
                          {role.period}
                        </div>
                        <div class="sm:col-span-3">
                          <h5 class="font-bold text-slate-850 text-md leading-snug">
                            {role.title}
                          </h5>
                          {role.bullets && role.bullets.length > 0 && (
                            <ul class="list-disc list-inside text-sm text-slate-600 mt-2 space-y-1">
                              {role.bullets.map((b) => (
                                <li>{b}</li>
                              ))}
                            </ul>
                          )}
                        </div>
                      </div>
                    ))}
                  </div>
                ) : (
                  /* Helyőrző állapot, ha az adott szervezetnél még nincs rögzített tevékenység */
                  <p class="text-sm italic text-slate-400 pl-4">
                    Nincs rögzített tevékenység / No recorded activities
                  </p>
                )}
              </div>
            ))
          }
        </div>
      </CVSection>

      <CVSection title={labels.awards}>
        <div class="space-y-4">
          {
            cv.awards.map((award) => (
              <div class="flex items-start gap-6 text-sm">
                <span class="font-semibold text-slate-500 tabular-nums w-12">
                  {award.year}
                </span>
                <div>
                  <span class="font-bold text-slate-900">{award.title}</span> —
                  <span class="text-slate-600 italic">{award.institution}</span>
                </div>
              </div>
            ))
          }
        </div>
      </CVSection>

      <CVSection title={labels.skills}>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {
            cv.skills.map((skill) => (
              <div class="flex items-center justify-between p-2 border-b border-slate-100">
                <span class="text-sm font-medium text-slate-800">
                  {skill.name}
                </span>
                <SkillRating level={skill.level} />
              </div>
            ))
          }
        </div>
      </CVSection>
    </main>
  </div>
</BaseLayout>
