---
interface Props {
  level: 1 | 2 | 3 | 4 | 5 | 6;
}
const { level } = Astro.props;
const maxCircles = 6;
---

<div class="flex gap-1.5" aria-label={`Szint: ${level} a 6-ból`}>
  {
    Array.from({ length: maxCircles }).map((_, index) => (
      <span
        class={`w-3 h-3 rounded-full border border-slate-950 transition-colors ${
          index < level ? 'bg-slate-950' : 'bg-transparent'
        }`}
      />
    ))
  }
</div>
