---
// src/components/PostCard.astro
interface Props {
  title: string;
  date: Date;
  excerpt: string;
  url: string;
}

const { title, date, excerpt, url } = Astro.props;
const { lang } = Astro.params;

const formattedDate = date.toLocaleDateString(
  lang === 'hu' ? 'hu-HU' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
---

<article
  class="group border-b border-slate-100 py-6 first:pt-0 last:border-0 last:pb-0"
>
  <div
    class="text-xs text-slate-500 font-mono uppercase tracking-wider mb-2 tabular-nums"
  >
    {formattedDate}
  </div>
  <h3
    class="text-2xl font-bold text-slate-900 group-hover:text-blue-600 transition-colors leading-snug"
  >
    <a href={url}>
      {title}
    </a>
  </h3>
  <p class="text-slate-605 mt-3 text-sm leading-relaxed line-clamp-2">
    {excerpt}
  </p>
</article>
