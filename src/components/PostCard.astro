---
const { title, date, excerpt, url } = Astro.props;
---
<article class="py-6 border-b last:border-0 border-slate-100">
  <h3 class="text-xl font-bold hover:text-blue-700 transition">
    <a href={url}>{title}</a>
  </h3>
  <p class="text-xs text-slate-500 uppercase tracking-widest mt-1">
    {date.toLocaleDateString('hu-HU', { year:'numeric', month:'long', day:'numeric' })}
  </p>
  <p class="text-slate-700 mt-3 leading-relaxed">{excerpt}</p>
</article>